{
  "name": "@arpit-pm1/agentic-setup",
  "version": "1.0.6",
  "description": "Make any repository agentic-ready — AI context sync, Codegraph analysis, and readiness scoring",
  "type": "module",
  "bin": {
    "agentic-setup": "./dist/bin.js"
  },
  "license": "MIT",
  "author": "Arpit Malik",
  "files": [
    "dist/**/*.js",
    "templates/**",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/bin.js",
    "./package.json": "./package.json"
  },
  "keywords": [
    "agentic",
    "ai-agent",
    "claude-code",
    "cursor",
    "codegraph",
    "coding-agent",
    "developer-tools",
    "ai-config",
    "cli"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "packageManager": "pnpm@11.13.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arpit-pm1/agentic-setup.git"
  },
  "bugs": {
    "url": "https://github.com/arpit-pm1/agentic-setup/issues"
  },
  "homepage": "https://github.com/arpit-pm1/agentic-setup#readme",
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "dev:install": "pnpm run build && pnpm link --global",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "ci:check": "pnpm run lint && pnpm run format:check && npx tsc --noEmit && pnpm test && pnpm run build",
    "readme:badges": "tsx scripts/generate-readme-badges.ts",
    "readme:badges:check": "tsx scripts/generate-readme-badges.ts --check",
    "publish:release": "pnpm publish --tag latest",
    "publish:alpha": "pnpm publish --tag alpha",
    "publish:beta": "pnpm publish --tag beta",
    "publish:rc": "pnpm publish --tag rc",
    "prepare": "husky",
    "version-bump:patch": "release-it patch --ci --verbose",
    "version-bump:minor": "release-it minor --ci --verbose",
    "version-bump:major": "release-it major --ci --verbose",
    "version-bump:alpha": "release-it prerelease --preRelease=alpha --ci --verbose --no-plugins",
    "version-bump:beta": "release-it prerelease --preRelease=beta --ci --verbose --no-plugins",
    "version-bump:rc": "release-it prerelease --preRelease=rc --ci --verbose --no-plugins",
    "version:print": "node -p \"require('./package.json').version\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@anthropic-ai/vertex-sdk": "^0.19.0",
    "@clack/prompts": "^1.7.0",
    "chalk": "^5.4.0",
    "commander": "^15.0.0",
    "diff": "^9.0.0",
    "glob": "^13.0.6",
    "google-auth-library": "^10.7.0",
    "openai": "^6.47.0",
    "ora": "^9.4.1",
    "p-limit": "^7.3.0",
    "posthog-node": "^5.42.0",
    "web-tree-sitter": "^0.26.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/diff": "^8.0.0",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "balanced-match": "4.0.4",
    "brace-expansion": "5.0.7",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-deep-equal": "3.1.3",
    "fast-uri": "3.1.3",
    "husky": "^9.1.7",
    "json-schema-traverse": "1.0.0",
    "lint-staged": "^17.0.8",
    "minimatch": "10.2.5",
    "prettier": "^3.9.5",
    "release-it": "^20.2.1",
    "tsdown": "^0.22.7",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "unrun": "^0.3.1",
    "vitest": "^4.0.18",
    "zod": "4.4.3"
  },
  "overrides": {
    "google-auth-library": "^10.7.0"
  },
  "inlinedDependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "balanced-match": "4.0.4",
    "brace-expansion": "5.0.7",
    "fast-deep-equal": "3.1.3",
    "fast-uri": "3.1.3",
    "json-schema-traverse": "1.0.0",
    "minimatch": "10.2.5",
    "zod": "4.4.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
