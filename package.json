{
  "name": "agentic-setup",
  "version": "1.0.0",
  "description": "Make any repository agentic-ready — AI context sync, Codegraph analysis, and readiness scoring",
  "type": "module",
  "bin": {
    "agentic-setup": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "dev:install": "npm run build && npm link",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "ci:check": "npm run lint && npm run format:check && npx tsc --noEmit && npm test && npm run build",
    "publish:release": "npm publish --access public --provenance --tag latest",
    "publish:alpha": "npm publish --access public --tag alpha",
    "publish:beta": "npm publish --access public --tag beta",
    "publish:rc": "npm publish --access public --tag rc",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@anthropic-ai/vertex-sdk": "^0.14.4",
    "@inquirer/checkbox": "^5.1.0",
    "@inquirer/confirm": "^6.0.8",
    "@inquirer/input": "^5.0.11",
    "@inquirer/select": "^5.1.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "diff": "^8.0.3",
    "glob": "^13.0.6",
    "google-auth-library": "^9.0.0",
    "openai": "^6.29.0",
    "ora": "^8.1.0",
    "p-limit": "^5.0.0",
    "posthog-node": "^5.28.2"
  },
  "files": [
    "dist/**/*.js",
    "templates/**",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "author": "Arpit Malik",
  "keywords": [
    "agentic",
    "ai-agent",
    "claude-code",
    "cursor",
    "codegraph",
    "coding-agent",
    "developer-tools",
    "ai-config",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/arpit-pm1/agentic-setup.git"
  },
  "bugs": {
    "url": "https://github.com/arpit-pm1/agentic-setup/issues"
  },
  "homepage": "https://github.com/arpit-pm1/agentic-setup#readme",
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "memfs": "^4.56.10",
    "prettier": "^3.8.1",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.0.18"
  }
}
